{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "./",
    "types": ["node", "hardhat"]
  },
  "include": [
    "./scripts",
    "./test",
    "./typechain",
    "./ignition/modules",
    "./contracts"
  ],
  "exclude": ["node_modules", "dist"]
}
